{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(git init *)",
      "Bash(npm run format:check)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run start:dev)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-generated-edit.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-on-save.sh\""
          }
        ]
      }
    ]
  }
}
